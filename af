#!/usr/bin/env bash
set -euo pipefail

# Run the latest develop version of agent-fox via uvx with Vertex support.
# This avoids conflicts with any local development checkout.
#
#   af code --project ~/projects/my-app   # normal usage
#   af update                             # pull latest develop

AF_FROM="agent-fox[vertex] @ git+https://github.com/agent-fox-dev/agent-fox-v2.git@develop"

if [[ "${1:-}" == "update" ]]; then
    echo "Updating af → agent-fox@develop[vertex] …"
    uvx --refresh --from "$AF_FROM" agent-fox --version
    echo "Done."
    exit
fi

exec uvx --from "$AF_FROM" agent-fox "$@"
